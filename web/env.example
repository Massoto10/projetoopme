# Projeto OPME — copie para .env e preencha.

# --- Postgres no Docker (npm run docker:db) — porta publicada 5433 no host
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/portal_pacotes?schema=public"

# --- Postgres local (sem Docker) na porta padrão
# DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/portal_pacotes?schema=public"

# Se no futuro usar Postgres atrás de pooler (ex.: Supabase) e precisar de URL direta para migrations,
# adicione no prisma/schema.prisma: directUrl = env("DIRECT_URL") e defina DIRECT_URL aqui.

# Auth.js / NextAuth — gere: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# Em produção (Vercel), defina AUTH_URL como a URL pública do site, ex.: https://portal-pacotes.vercel.app
AUTH_URL="http://localhost:3000"

# Seed do primeiro admin (npm run db:seed)
INIT_ADMIN_EMAIL="admin@local.dev"
INIT_ADMIN_PASSWORD="defina-uma-senha-forte-8-plus"
INIT_ADMIN_NAME="Administrador"

{
  "name": "projeto-opme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:clear-pacotes": "npx tsx prisma/clear-pacotes.ts",
    "db:import-hospitais": "npx tsx prisma/import-hospitais.ts",
    "db:extract-pacotes-tsv": "node prisma/extract-pacotes-tsv.cjs",
    "db:import-pacotes": "node prisma/extract-pacotes-tsv.cjs && npx tsx prisma/import-pacotes-carga.ts",
    "docker:db": "docker compose up -d db",
    "docker:db:down": "docker compose down",
    "docker:up": "docker compose --profile full up -d --build",
    "docker:down": "docker compose --profile full down"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
